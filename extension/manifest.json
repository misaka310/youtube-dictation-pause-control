{
  "manifest_version": 3,
  "name": "YouTube Dictation Pause Control",
  "version": "1.2.0",
  "description": "音声入力中だけYouTubeの再生を自動で一時停止し、終了時に録音開始時点で再生中だった動画だけを再開します。(HTTP Bridge / BG fetch)",
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:17654/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
